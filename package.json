{
  "name": "user-core",
  "version": "0.1.0",
  "private": true,
  "description": "Infrastructure de compte et d'identité de l'écosystème",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "prepare": "git config core.hooksPath .githooks",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/main.js",
    "start:dev": "ts-node src/main.ts",
    "migrate": "ts-node scripts/migrate.ts",
    "lint": "eslint .",
    "test": "jest",
    "start:worker": "node dist/src/worker.js",
    "start:worker:dev": "ts-node src/worker.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "argon2": "^0.44.0",
    "dotenv": "^16.4.5",
    "pg": "^8.13.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "eslint": "^10.7.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.64.0"
  }
}
