# Copier vers .env (jamais committé). Valeurs = Postgres de dev docker-compose.
# Les secrets réels (staging/prod) vivent dans Vault/Infisical, jamais ici.
# Le service REFUSE de démarrer si la config est incomplète : toutes les
# violations sont listées d'un bloc au boot (patron payment-core).

# LE SERVICE : rôle applicatif BRIDÉ, et lui seul. Au boot, le service vérifie
# SELECT current_user et refuse de tourner sous un autre rôle — une URL
# propriétaire ici ne démarre pas.
# (Le mot de passe dev du rôle est posé par le harnais de test via ALTER ROLE :
# lancer « npm test » une fois après « npm run migrate ».)
DATABASE_URL=postgres://user_core_app:user_core_app_dev_only@localhost:5434/user_core
PORT=3000

# ADMINISTRATION : propriétaire de la base — scripts/migrate.ts et le harnais
# de test UNIQUEMENT. Le service ne lit JAMAIS cette variable.
DATABASE_ADMIN_URL=postgres://user_core:user_core_dev@localhost:5434/user_core

# Mot de passe du rôle applicatif bridé (dev/CI UNIQUEMENT) : posé par le
# harnais de test via ALTER ROLE, jamais par une migration. Prod : Vault.
# Doit rester cohérent avec DATABASE_URL ci-dessus.
USER_CORE_APP_PASSWORD=user_core_app_dev_only

# --- Authentification (LOT 1) --------------------------------------------------
# TTL du jeton d'accès : borné EN DUR à 900 s (C2) — le service refuse de
# booter au-delà. La révocation serveur ne rattrape pas un jeton déjà émis.
AUTH_ACCESS_TOKEN_TTL_SECONDS=900

# Clés Ed25519 de signature des jetons d'accès : { kid: base64(PKCS8 DER) }.
# kid dans l'en-tête dès le premier jeton — la rotation n'est jamais une crise.
# AUCUNE clé ici, même de dev (C14, patron payment-core) : un .env.example
# qui contient une clé qui marche finit copié tel quel en staging. Chaque
# poste génère la SIENNE — le boot refuse de démarrer tant qu'elle manque,
# et le bloc de violations dit exactement quoi faire :
#   node -e "const{generateKeyPairSync}=require('crypto');console.log(generateKeyPairSync('ed25519').privateKey.export({format:'der',type:'pkcs8'}).toString('base64'))"
# AUTH_SIGNING_KEYS={"DEV1":"<base64-pkcs8-der>"}
# AUTH_ACTIVE_KEY_ID=DEV1

# Paramètres argon2id (C7) — défauts explicites : 64 MiB, 3 passes, p=4.
# Un durcissement = changer ici + re-hash à la connexion, jamais une migration.
AUTH_ARGON2_MEMORY_COST=65536
AUTH_ARGON2_TIME_COST=3
AUTH_ARGON2_PARALLELISM=4

# Verrouillage progressif (C8) : au seuil, verrou = base × 2^(échecs − seuil),
# plafonné. La base garantit qu'un verrou futur ne recule jamais.
AUTH_LOCK_THRESHOLD=5
AUTH_LOCK_BASE_SECONDS=60
AUTH_LOCK_CAP_SECONDS=3600

# Sessions (LOT 1, étape 8) : durées en config, jamais figées dans le code.
AUTH_REFRESH_TTL_SECONDS=604800
AUTH_SESSION_ABSOLUTE_TTL_SECONDS=2592000
AUTH_GRACE_WINDOW_SECONDS=30

# Throttle du login : par IP ET par identifiant visé (Q3).
AUTH_THROTTLE_MAX_ATTEMPTS=10
AUTH_THROTTLE_WINDOW_SECONDS=60

# --- Inscription publique (LOT 4) ----------------------------------------------
# L'identifiant est GÉNÉRÉ par le service (CSPRNG) : personne ne le choisit,
# rien à énumérer. Throttle par IP SEULE, budget distinct du login.
#
# ⚠️ FAIT DE TERRAIN (F-terrain, Auditeur 15/07/2026) : en RDC une très large
# part du trafic mobile passe par du CGNAT opérateur — des milliers d'abonnés
# derrière une poignée d'IP publiques. La valeur de PROD de ce plafond est un
# ARBITRAGE TERRAIN qui appartient à Kevin (généreuse, sinon la 6e famille
# légitime derrière l'IP Vodacom est refusée). Le vrai mur anti-abus est
# ailleurs : l'inscription n'envoie AUCUN SMS (vérification paresseuse) et le
# coût argon2 freine déjà — ce throttle protège le CPU, pas l'argent.
# La valeur ci-dessous est un plancher de DEV/TEST, pas une recommandation.
AUTH_SECRET_MIN_LENGTH=8
AUTH_REGISTER_THROTTLE_MAX_ATTEMPTS=5
AUTH_REGISTER_THROTTLE_WINDOW_SECONDS=3600

# --- Authentification des PROGRAMMES (LOT 4, étape 6) ---------------------------
# Le programme génère sa paire Ed25519 CHEZ LUI et n'envoie que la clé
# publique (scripts/program-client-admin.ts). Pour obtenir un jeton, il
# présente une assertion signée (JWT EdDSA : iss=client_id, jti unique,
# aud=user-core, exp court) — le rejeu est bloqué PAR LA BASE (013).
# Jeton de programme : borne dure 900 s (C2), comme les comptes.
PROGRAM_TOKEN_TTL_SECONDS=900
PROGRAM_ASSERTION_MAX_TTL_SECONDS=300
PROGRAM_TOKEN_THROTTLE_MAX_ATTEMPTS=30
PROGRAM_TOKEN_THROTTLE_WINDOW_SECONDS=60
# Budget MÉTIER de /v1, par client authentifié — distinct du budget de
# /v1/token (les deux surfaces ne partagent pas leurs tentatives).
PROGRAM_API_THROTTLE_MAX_ATTEMPTS=120
PROGRAM_API_THROTTLE_WINDOW_SECONDS=60

# --- Trousseaux (LOT 2) : DEUX trousseaux, DEUX cycles de vie ------------------
# Aucune clé fonctionnelle ici (patron payment-core) : chaque poste génère les
# siennes, le boot refuse de démarrer tant qu'elles manquent.
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#
# CHIFFREMENT (AES-256-GCM, 32 octets EXACTS) : tourner la clé active suffit,
# les anciennes valeurs restent déchiffrables par leur enc_key_id.
# USER_CORE_ENC_KEYS={"E1":"<base64-32-octets>"}
# USER_CORE_ENC_ACTIVE_KEY_ID=E1
#
# EMPREINTE (HMAC-SHA256, 32 octets minimum) : tourner cette clé oblige à
# déchiffrer ET re-hacher TOUTE la PII (CDC §6.1) — procédure exceptionnelle,
# migration signée, JAMAIS un réflexe. Une clé ne sert jamais aux deux usages :
# le boot refuse si les deux trousseaux partagent une valeur.
# USER_CORE_HMAC_KEYS={"H1":"<base64-32-octets>"}
# USER_CORE_HMAC_ACTIVE_KEY_ID=H1
#
# CODES DE POSSESSION (HMAC-SHA256, 32 octets minimum) — TROISIÈME trousseau,
# distinct des deux autres : un code à 6 chiffres vit dans un espace de 10⁶,
# un condensat non salé se retourne en quelques secondes. Le compromettre ne
# compromet ni les numéros ni leur unicité.
# USER_CORE_PROOF_CODE_KEYS={"C1":"<base64-32-octets>"}
# USER_CORE_PROOF_CODE_ACTIVE_KEY_ID=C1

# --- Preuve de possession (LOT 2) : AUCUNE valeur de terrain figée ------------
# Prix du flash call, disponibilité SNA, plafonds réels : inconnues de terrain
# (CDC §9) — elles appartiennent à Kevin. Ici, on PARAMÈTRE.
PROOF_CODE_DIGITS=6
PROOF_CODE_TTL_SECONDS=300
PROOF_MAX_ATTEMPTS=3
# Plafond par LIGNE (pas par compte) : il protège le téléphone d'un TIERS.
PROOF_LINE_CAP=3
PROOF_LINE_CAP_WINDOW_SECONDS=86400

# --- Worker de drainage de l'outbox (LOT 3) ------------------------------------
# UN publisher, PENDING -> PUBLISHED (ou FAILED après N tentatives). Le plafond
# est la garde qui empêche un événement indélivrable de tourner en boucle sur un
# canal payant : un bug ne doit pas pouvoir coûter une fortune dans la nuit.
WORKER_TICK_INTERVAL_MS=5000
OUTBOX_BATCH_SIZE=20
OUTBOX_LEASE_SECONDS=120
OUTBOX_MAX_ATTEMPTS=5
OUTBOX_BACKOFF_BASE_SECONDS=30
OUTBOX_BACKOFF_CAP_SECONDS=3600
