# Copier vers .env (jamais committé). Valeurs = Postgres de dev docker-compose.
# Les secrets réels (staging/prod) vivent dans Vault/Infisical, jamais ici.
# Le service REFUSE de démarrer si la config est incomplète : toutes les
# violations sont listées d'un bloc au boot (patron payment-core).

# LE SERVICE : rôle applicatif BRIDÉ, et lui seul. Au boot, le service vérifie
# SELECT current_user et refuse de tourner sous un autre rôle — une URL
# propriétaire ici ne démarre pas.
# (Le mot de passe dev du rôle est posé par le harnais de test via ALTER ROLE :
# lancer « npm test » une fois après « npm run migrate ».)
DATABASE_URL=postgres://user_core_app:user_core_app_dev_only@localhost:5434/user_core
PORT=3000

# ADMINISTRATION : propriétaire de la base — scripts/migrate.ts et le harnais
# de test UNIQUEMENT. Le service ne lit JAMAIS cette variable.
DATABASE_ADMIN_URL=postgres://user_core:user_core_dev@localhost:5434/user_core

# Mot de passe du rôle applicatif bridé (dev/CI UNIQUEMENT) : posé par le
# harnais de test via ALTER ROLE, jamais par une migration. Prod : Vault.
# Doit rester cohérent avec DATABASE_URL ci-dessus.
USER_CORE_APP_PASSWORD=user_core_app_dev_only
